{
	"consumer": {
		"name": "video-editor-client"
	},
	"interactions": [
		{
			"description": "a request for all devices",
			"pending": false,
			"request": {
				"headers": {
					"Authorization": ["Bearer some-test-token"]
				},
				"matchingRules": {
					"header": {
						"Authorization": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						}
					}
				},
				"method": "GET",
				"path": "/v1/devices"
			},
			"response": {
				"body": {
					"content": {
						"devices": [
							{
								"createdAt": "2024-01-01T00:00:00Z",
								"deviceId": "device-123",
								"deviceName": "Test Camera",
								"updatedAt": "2024-01-01T00:00:00Z"
							}
						]
					},
					"contentType": "application/json",
					"encoded": false
				},
				"headers": {
					"Content-Type": ["application/json"]
				},
				"matchingRules": {
					"body": {
						"$.devices": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type",
									"min": 1
								}
							]
						},
						"$.devices[*].createdAt": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.devices[*].deviceId": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.devices[*].deviceName": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.devices[*].updatedAt": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						}
					}
				},
				"status": 200
			},
			"type": "Synchronous/HTTP"
		},
		{
			"description": "a request to create a device",
			"pending": false,
			"request": {
				"body": {
					"content": {
						"deviceName": "New Camera"
					},
					"contentType": "application/json",
					"encoded": false
				},
				"headers": {
					"Authorization": ["Bearer some-test-token"],
					"Content-Type": ["application/json"]
				},
				"matchingRules": {
					"body": {
						"$.deviceName": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						}
					},
					"header": {
						"Authorization": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"Content-Type": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						}
					}
				},
				"method": "POST",
				"path": "/v1/devices"
			},
			"response": {
				"body": {
					"content": {
						"device": {
							"createdAt": "2024-01-01T00:00:00Z",
							"deviceId": "device-456",
							"deviceName": "New Camera",
							"updatedAt": "2024-01-01T00:00:00Z"
						},
						"message": "Device created successfully"
					},
					"contentType": "application/json",
					"encoded": false
				},
				"headers": {
					"Content-Type": ["application/json"]
				},
				"matchingRules": {
					"body": {
						"$.device.createdAt": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.device.deviceId": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.device.deviceName": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.device.updatedAt": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						},
						"$.message": {
							"combine": "AND",
							"matchers": [
								{
									"match": "type"
								}
							]
						}
					}
				},
				"status": 201
			},
			"type": "Synchronous/HTTP"
		}
	],
	"metadata": {
		"pact-js": {
			"version": "16.5.0"
		},
		"pactRust": {
			"ffi": "0.5.4",
			"models": "1.3.11"
		},
		"pactSpecification": {
			"version": "4.0"
		}
	},
	"provider": {
		"name": "fragment-composer"
	}
}
